bindkey '^ ' autosuggest-accept

addtask() {
	args="${@:2}"
	~/scripts/agenda/mchauras-add-task.sh $1 "$args"
}

loop-over() {
    if [[ $# -lt 2 ]]; then
	echo "Usage: loop-over <count> <command...>"
	return 1
    fi

    local count=$1
    shift

    for ((i=1; i<=count; i++)); do
	echo "---- Run $i/$count ----"
	"$@"
    done
}

gdb-tmux() {
    local session="gdb-session"

    # Not inside tmux -> create session and re-enter function
    if [ -z "$TMUX" ]; then
        tmux new-session -d -s "$session" \
            "zsh -ic 'gdb-tmux $*'"

        tmux attach-session -t "$session"
        return
    fi

    # Create right pane for registers (66% width)
    local reg_pane
    reg_pane="$(tmux split-pane -h -p 66 -PF '#D' 'cat')"

    # Get tty of register pane
    local reg_tty
    reg_tty="$(tmux display-message -p -t "$reg_pane" '#{pane_tty}')"

    # Return focus to left pane
    tmux last-pane

    # Cleanup pane on exit/error
    trap "tmux kill-pane -t '$reg_pane' 2>/dev/null" EXIT

    # Run gdb in current pane
    gdb \
        -ex "dashboard -layout source assembly registers" \
        -ex "dashboard registers -output $reg_tty" \
        "$@"
}